{
  "#00": "This is a comment. This file is an example. Modify before use!",

  "max_run_hours": 0,
  "sleep_seconds": 15,

  "#01": "This defines a list of log files we watch for new lines.",
  "#02": "Lines matching regexes in `log_events` trigger the named events.",
  "log_files": [
    "/var/log/lighttpd/access.log",
    "/var/log/apache2/access.log"
  ],
  "log_events": [
    ["/events/\\?(?:bootstrapped|cron_hourly)=(?P<re_host>[A-Za-z0-9_-]+)",
                                                               "HOST_LIVE"],
    ["/events/\\?(?P<re_event>backup_ready|drain|undrain)=(?P<re_host>[A-Za-z0-9_-]+)",
                                                               "HOST_EVENT"],
    ["/events/\\?backup_ready=(?P<re_host>[A-Za-z0-9_-]+)",    "BACKUP_READY"],
    ["/events/\\?site_update=(?P<re_domain>[A-Za-z0-9\\.-]+)", "SITE_UPDATE"],
    ["/(events|ping)/\\?git_update=\\S+",                      "GIT_UPDATE"]
  ],

  "#11": "These are regeps against: Weekday Month YYYY-MM-DD HHhMMmSSs",
  "#12": "The granularity is once/minute (SS undefined), while the runner runs.",
  "#13": "Spaces in the regexp are treated as match-anything wildcards",
  "scheduled_events": {
    "h[012345][02468]m":      "UPDATE_METRICS",
    "(Thur|Tue)sday 2[123]h": "BEER_EVENT"
  },

  "#21": "This section is used by update_variables.py.",
  "#22": "Defines how variables propagate from one file to another.",
  "#23": "Mostly version numbers changing, triggering deployments.",
  "#24": "Pre-conditions will block updates e.g. if a canary is sad.",
  "update_variables": [
    {
      "pre_conditions": {},
      "read": ["tree/manifest-packages.json"],
      "map": {
        "manifest_tool1_latest": "tool1_version",
        "manifest_tool2_latest": "tool2_version"
      },
      "write": ["tree/canaries/web-*/009_automation.json"],
      "emit_events": ["REBUILD"]
    },
    {
      "pre_conditions": {},
      "group_by": ["tree/hosts-*"],
      "read": ["$GROUP/*/host.json"],
      "map": {
        "g8r_hosts": "g8r_hosts"
      },
      "write": ["$GROUP/009_automation.json"],
      "emit_events": ["REBUILD"]
    },
    {
      "pre_conditions": {},
      "read": ["private/backups/*/manifest.json"],
      "map": {
        "g8r_backups": "g8r_backups"
      },
      "write": ["tree/manifest-backups.json"],
      "emit_events": ["REBUILD"]
    },
    {
      "pre_conditions": {},
      "group_by": ["tree/hosts-*"],
      "read": ["$GROUP/*/800_update-schedule.json"],
      "map": {
        "g8r_update_schedule": "g8r_update_schedule"
      },
      "write": ["$GROUP/009_automation.json"],
      "emit_events": ["REBUILD"]
    },
    {
      "pre_conditions": {},
      "read": ["tree/status/host-*.json"],
      "map": {
        "status": "status"
      },
      "write": ["tree/status/summary.json"],
      "emit_events": ["REBUILD"]
    }
  ],

  "#91": "These are the automations themselves: names and shell commands.",
  "#92": "They always run in the same order, at most one at a time.",
  "#93": "Automations may output 'AUTOMATION: NAME' to STDOUT to trigger",
  "#94": "further processing, e.g. updated variables trigginrg a rebuild.",
  "automations": [
    ["BEER_EVENT",      "echo", "$ts"],
    ["HOST_LIVE",       "event-handle.sh", "seen", "$re_host", "$log_ip", "$log_time"],
    ["HOST_EVENT",      "event-handle.sh", "$re_event", "$re_host", "$log_ip", "$log_time"],
    ["UPDATE_METRICS",  "metrics-get.sh", "-A"],
    ["BACKUP_READY",    "backups-fetch.sh", "$re_host"],
    ["GIT_UPDATE",      "/path/to/bin/update-git-repos.sh"],
    ["SITE_UPDATE",     "/path/to/bin/update-site-content.sh", "$re_domain"],
    ["VARS_UPDATE",     "update_variables.py"],
    ["REBUILD",         "g8r", "make"]
  ]
}
