<!DOCTYPE html>
<html lang="en">
<head>
{%- block head %}
  <meta charset="utf-8">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🔨</text></svg>">
  {%- if page and page.redirect %}
  <meta http-equiv="refresh" content="0; url={{ page.redirect }}">
  {%- endif %}
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
  <style type="text/css">
/* ***************************************************************************** */

{{ cat('/jinja/style.css')|safe }}

/* ***************************************************************************** */
  </style>
  <title>Governator: {% block title %}bash|curl ftw{% endblock %}</title>
  {%- if page and page.type in ('blog', 'blog2') %}
  <script src="/blog/nav.js"></script>
  {%- endif -%}
  {%- block head_extra %}{% endblock %}
{%- endblock %}
</head><body>
{%- block navigation %}
  <div id="navigation"></div>
{%- endblock %}
  <a style="position: absolute; top: 0;" name="top"></a>
  <div id="content">
{%- if not page or not page.type == 'full' %}
  {%- block page_top %}
    <div id="content-header"></div>
  {%- endblock %}
    <div id="content-pages">
{%- endif %}
<!-- -------------------------------------------------------------------------- -->

{%- block content %}{% endblock %}

<!-- -------------------------------------------------------------------------- -->
{%- if not page or not page.type == 'full' %}
    </div><!-- id=content-pages -->
  {%- if page and page.type in ('blog', 'blog2') %}
    <div class='blog-nav'>
      <p class='prev'></p><p class='next'></p>
    </div>
  {%- endif %}
{%- endif %}
{%- block page_bottom %}
    <div id="footer">
      <p class="rebuilt">
        Bashed at {{ now|date('%H:%M, %Y-%m-%d') }} by the
        <a href="https://github.com/pagekite/g8r/" target=_blank>Governator</a>.
      </p>
    </div>
{%- endblock %}

  </div><!-- id=content -->
  <div id="scroll-hint">
    <a href="#top"><img title="Page top" alt="🠉" src="/jinja/imgs/arrow-up.png"></a>
  </div>
{%- block tail %}{% endblock %}
</body></html>
