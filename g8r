#!/bin/bash
[ "${G8R_DEBUG:-n}" != "n" ] && set -x
set -euo pipefail
export G8R_HOME=${G8R_HOME:-"$(cd "$(dirname "$0")" && pwd)"}
export G8R_TOOLS="$G8R_HOME/tools"
export G8R_TREE="$G8R_HOME/tree"
export PATH="$G8R_HOME:$G8R_TOOLS:$PATH"

[ "${PAGER:-}" = "" ] && PAGER=$(which less && echo '-XF')
[ "${PAGER:-}" = "" ] && PAGER=$(which more)
[ "${PAGER:-}" = "" ] && PAGER="cat"

COMMAND="${1:-}"
shift || true

case "$COMMAND" in

    automate)
        exec "$G8R_TOOLS"/automation_runner.py "$@"
        ;;

    make)
        "$G8R_TOOLS"/update_variables.py
        cd "$G8R_HOME"/tree
        make "$@" || make "$@"
        ;;

    init)
        exec "$G8R_TOOLS"/init.sh
        ;;

    host-secret | host-dir)
        cd "$G8R_HOME"
        # shellcheck disable=SC1091 ## Don't expect shellcheck to check the vars
        source tree/000_base.vars
        target="$1"
        if cd tree/hosts-*/"$target" 2>/dev/null; then
            if [ "$COMMAND" = "host-dir" ]; then
                p=$(pwd)
                echo "$(basename "$(dirname "$p")")/$(basename "$p")"
            else
                echo "$target"
            fi
            exit 0
        fi
        host_name=${target/%.*/}
        host_domain=${target/#${host_name}./}
        [ "$host_domain" = "$host_name" ] \
            && host_domain="${g8r_governating_domain:?Default domain unset, please run: g8r init}"

        if cd tree/hosts-"$host_domain" 2>/dev/null; then
            host_secret=$(jq .g8r_hosts"[\"$host_name\"]".secret config-cache.json)
            host_secret=${host_secret//\"/}
            if [ "$host_secret" != "" ] && [ "$host_secret" != null ]; then
                if [ "$COMMAND" = "host-dir" ]; then
                    echo "$(basename "$(pwd)")/$host_secret"
                else
                    echo "$host_secret"
                fi
                exit 0
            fi
        fi
        echo "Host not found for '$target'" >&2
        exit 1
        ;;

    host-cfg)
        [ "${1:-}" = '--json' ] && T="json" && shift || T="sh"
        target=$(g8r host-dir "${1:-}")
        [ "$target" = "" ] && echo "Usage: g8r host-cfg [--json] <host>" >&2 && exit 1
        umask 0077
        cd "$G8R_HOME"
        if cd tree/"$target" 2>/dev/null; then
            target_dir=$(pwd)
            ln -s ../../recipes/config-cache.jinja-$T .g8r-tmp-$$.jinja-$T
            (cd "$G8R_HOME/tree" \
                && make "$target_dir"/.g8r-tmp-$$.$T >/dev/null \
                && cat "$target_dir"/.g8r-tmp-$$.$T)
            rm -f .g8r-tmp-*
            exit 0
        fi
        echo "Host config not found for '$target'" >&2
        exit 1
        ;;

    hosts)
        MODE=all
        [ "${1:-}" = "-s" ] && MODE=hsec && shift
        [ "${1:-}" = "-i" ] && MODE=addr && shift
        [ "${1:-}" = "-4" ] && MODE=ipv4 && shift
        [ "${1:-}" = "-6" ] && MODE=ipv6 && shift
        [ "${1:-}" = "-n" ] && MODE=fqdn && shift
        [ "${1:-}" = "-d" ] && MODE=hdir && shift

        cd "$G8R_HOME"/tree
        # shellcheck disable=SC2125
        DOMAINS=hosts-*
        [ "${1:-}" = "-d" ] && DOMAINS="hosts-$2" && shift && shift

        G8R_HOST_LIMIT="${G8R_HOST_LIMIT:-}"
        [ "${1:-}" = "-l" ] && G8R_HOST_LIMIT="$2" && shift && shift
        export G8R_HOST_LIMIT

        [ "${1:-}" != "" ] && cat "$G8R_HOME/docs/help/hosts.txt" && exit 1

        for ddir in $DOMAINS; do
            # shellcheck disable=SC2015,SC2010
            HOST_DIRS=$(cd "$ddir" && ls -d1 -- *-*-* | grep -e "$G8R_HOST_LIMIT" || true)
            for host_secret in $HOST_DIRS; do
                host_dir="$ddir/$host_secret"
                if [ -e "$host_dir/host.json" ]; then
                    case $MODE in
                        hsec)
                            echo "$host_secret"
                            ;;
                        hdir)
                            echo "$host_dir"
                            ;;
                        *)
                            # shellcheck disable=SC1090,SC1091
                            source <(g8r host-cfg "$host_secret")
                            ipv4=$(jq ".g8r_hosts[\"${host_name}\"].ipv4[0]" "$host_dir/host.json")
                            ipv4=${ipv4//\"/}
                            ipv4=${ipv4//null/-}
                            ipv6=$(jq ".g8r_hosts[\"${host_name}\"].ipv6[0]" "$host_dir/host.json")
                            ipv6=${ipv6//\"/}
                            ipv6=${ipv6//null/-}
                            case $MODE in
                                all)
                                    printf "%15s %32s %-19s %s\\n" \
                                        "$ipv4" "$ipv6" "$host_name.$host_domain" "$host_secret"
                                    ;;
                                ipv4)
                                    [ "$ipv4" != "-" ] && echo "$ipv4"
                                    ;;
                                ipv6)
                                    [ "$ipv6" != "-" ] && echo "$ipv6"
                                    ;;
                                addr)
                                    if [ "$ipv4" != "-" ]; then
                                        echo "$ipv4"
                                    else
                                        if [ "$ipv6" != "-" ]; then
                                            echo "$ipv6"
                                        fi
                                    fi
                                    ;;
                                fqdn)
                                    echo "$host_name.$host_domain"
                                    ;;
                            esac
                            ;;
                    esac
                fi
            done
        done
        ;;

    host-info)
        target="$(g8r host-secret "${1:-}")"
        [ "$target" = "" ] && echo "Usage: g8r host-info <host>" >&2 && exit 1
        # shellcheck disable=SC1090,SC1091
        source <(g8r host-cfg "$target")
        host_dir="$G8R_HOME/tree/hosts-$host_domain/$target"
        ipv4=$(jq ".g8r_hosts[\"${host_name}\"].ipv4[0]" "$host_dir/host.json")
        ipv4=${ipv4//\"/}
        ipv6=$(jq ".g8r_hosts[\"${host_name}\"].ipv6[0]" "$host_dir/host.json")
        ipv6=${ipv6//\"/}
        # shellcheck disable=SC2154
        cat <<tac
Host FQDN: $host_name.$host_domain

IPv4: ${ipv4:-none}
IPv6: ${ipv6:-none}
Bootstrap URL:
    $g8r_url_base/hosts/$target/000_bootstrap.sh

tac
        ;;

    etc-hosts)
        echo "About to update /etc/hosts - sudo may prompt for a password." >&2
        for etc_hosts in ./tree/hosts-*/101_etc-hosts.sh; do
            sudo "${etc_hosts}"
        done
        ;;

    add-domain)
        exec "$G8R_TOOLS"/domain-add.sh "$@"
        ;;

    add-host)
        exec "$G8R_TOOLS"/host-add.sh "$@"
        ;;

    deploy)
        exec "$G8R_TOOLS"/host-deploy.sh "$@"
        ;;

    rm-host)
        [ "${1:-}" = "" ] && cat "$G8R_HOME/docs/help/rm-host.txt" && exit 1
        # shellcheck disable=SC2048 ## Happy for white-space to expand
        for H in $*; do
            H=$(g8r host-secret "$H")
            [ "$H" != "" ] && [ ! -e "exposed/hosts/$H/host.json" ] && echo -e "Host not found or ambiguous: $1" >&2
            if [ "$H" = "" ] || [ ! -e "exposed/hosts/$H/host.json" ]; then
                cat "$G8R_HOME/docs/help/rm-host.txt" >&2
                exit 1
            fi
            # shellcheck disable=SC1090,SC1091
            source <(g8r host-cfg "$H")
            HOST_DIR=$(cd tree/hosts-*/"$H" && pwd)
            HOST_FQDN="$host_name.$host_domain"
            echo -e "Press ENTER to remove $HOST_FQDN: (CTRL+C aborts)\\n - $HOST_DIR" >&2
            # shellcheck disable=SC2162 ## We do not care about the output
            read
            rm -vrf exposed/hosts/"$H" tree/hosts-*/"$H" tree/status/*"$H"*
            json_edit.py tree/hosts-"$host_domain"/009_automation.json \
                "g8r_hosts" remove "$host_name" \
                "g8r_update_schedule" remove "$host_name"
            json_edit.py tree/status/summary.json "status" remove "$H"
            json_edit.py tree/status/metrics.json "metrics" remove "$HOST_FQDN"
            echo "IMPORTANT: Run 'g8r make' to avoid stale data."
        done
        ;;

    metrics)
        exec "$G8R_TOOLS"/metrics-get.sh "$@"
        ;;

    ssh | scp-to | scp-from)
        G8R_SSH_IP=${G8R_SSH_IP:-ipv4}
        [ "${1:-}" = "-6" ] && G8R_SSH_IP=ipv6 && shift || true
        H=$(g8r host-secret "${1:-}")
        [ "$H" = "" ] && cat "$G8R_HOME/docs/help/ssh.txt" >&2 && exit 1
        shift
        # shellcheck disable=SC1090,SC1091
        source <(g8r host-cfg "$H")
        target=$(jq ".g8r_hosts[\"$host_name\"].$G8R_SSH_IP[0]" "$G8R_TREE"/hosts-*/"$H/host.json")
        [ "$target" = "null" ] && target="$host_name.$host_domain"
        target=${target//\"/}
        case "$COMMAND" in
            ssh)
                echo "Attempting: ssh -p ${g8r_sshd_port:-22} root@$target ..." >&2
                exec ssh -p "${g8r_sshd_port:-22}" "root@$target" "$@"
                ;;
            scp-to)
                tpath="$1"
                shift
                echo "Attempting: scp -P ${g8r_sshd_port:-22} ... root@$target:$tpath" >&2
                exec scp -P "${g8r_sshd_port:-22}" "$@" "root@$target:$tpath"
                ;;
            scp-from)
                tpath="$1"
                shift
                echo "Attempting: scp -P ${g8r_sshd_port:-22} root@$target:$tpath ..." >&2
                exec scp -P "${g8r_sshd_port:-22}" "root@$target:$tpath" "$@"
                ;;
        esac
        ;;

    update)
        G8R_SSH_IP=${G8R_SSH_IP:-ipv4}
        [ "${1:-}" = "-6" ] && G8R_SSH_IP=ipv6 && shift || true
        export G8R_SSH_IP

        G8R_PARALLEL=${G8R_PARALLEL:-n}
        if [ "${1:-}" = "-p" ]; then
            G8R_PARALLEL=y
            shift
        fi
        export G8R_PARALLEL
        [ "${1:-}" = "" ] && cat "$G8R_HOME/docs/help/update.txt" >&2 && exit 1
        # shellcheck disable=SC2046,SC2048,SC2086
        [ "$1" = "-a" ] && exec g8r update $(g8r hosts -s)
        # shellcheck disable=SC2046,SC2048,SC2086
        [ "$1" = "-d" ] && exec g8r update $(g8r hosts -s $*)
        # shellcheck disable=SC2046,SC2048,SC2086
        [ "$1" = "-l" ] && exec g8r update $(g8r hosts -s $*)
        # shellcheck disable=SC2048
        for host in $*; do
            if [ "$G8R_PARALLEL" = "y" ]; then
                g8r ssh "$host" g8r run --force 900_update.sh &
                sleep 1
            else
                g8r ssh "$host" g8r run --force 900_update.sh
            fi
        done
        ;;

    push)
        G8R_SSH_IP=${G8R_SSH_IP:-ipv4}
        [ "${1:-}" = "-6" ] && G8R_SSH_IP=ipv6 && shift || true
        export G8R_SSH_IP

        G8R_PARALLEL=${G8R_PARALLEL:-n}
        if [ "${1:-}" = "-p" ]; then
            G8R_PARALLEL=y
            shift
        fi
        export G8R_PARALLEL
        [ "${2:-}" = "" ] && cat "$G8R_HOME/docs/help/push.txt" >&2 && exit 1

        script="$1"
        shift

        ECODE=0
        # shellcheck disable=SC2046,SC2048,SC2086
        [ "$1" = "-a" ] && exec g8r push "$script" $(g8r hosts -s)
        # shellcheck disable=SC2046,SC2048,SC2086
        [ "$1" = "-d" ] && exec g8r push "$script" $(g8r hosts -s $*)
        # shellcheck disable=SC2046,SC2048,SC2086
        [ "$1" = "-l" ] && exec g8r push "$script" $(g8r hosts -s $*)
        # shellcheck disable=SC2048
        for host in $*; do
            host_dir=$(g8r host-dir "$host")
            if [ -e "$G8R_TREE/$host_dir/$script" ]; then
                tdir=/var/lib/g8r/scripts/
                if ! g8r scp-to "$host" "$tdir" "$G8R_TREE/$host_dir/$script"; then
                    g8r ssh "$host" mkdir -p "$tdir"
                    g8r scp-to "$host" "$tdir" "$G8R_TREE/$host_dir/$script"
                fi
                if [ "$G8R_PARALLEL" = "y" ]; then
                    g8r ssh "$host" "g8r run \"$script\" </dev/null >/dev/null 2>&1 &"
                else
                    g8r ssh "$host" g8r run "$script"
                fi
            else
                echo "Not found in $host_dir: $script" >&2
                ECODE=1
            fi
        done
        exit $ECODE
        ;;

    backups)
        cd "$G8R_HOME"
        backups-fetch.sh "$@"
        ;;

    ####[ Managed host only ]################################################

    ls)
        cd "$G8R_HOME"/scripts 2>/dev/null && ls -1d -- *.sh 2>/dev/null && exit 0
        echo "No g8r scripts installed (this command is only used on g8r managed hosts)." >&2
        exit 1
        ;;

    healthchk)
        if cd "$G8R_HOME"/scripts 2>/dev/null; then
            if [ "$1" = "-a" ]; then
                for s in $(g8r ls); do
                    fragment-run.sh "$G8R_HOME/scripts/$s" HEALTH_CHECK
                done
            else
                fragment-run.sh "$G8R_HOME/scripts/$1" HEALTH_CHECK
            fi
        else
            echo "No g8r scripts installed (this command is only used on g8r managed hosts)." >&2
        fi
        ;;

    run)
        G8R_FORCE=n
        [ "${1:-}" = "--force" ] && G8R_FORCE=y && shift

        [ "${1:-}" = "" ] && echo "Run what? Try: g8r ls" >&2 && exit 1
        G8R_SCRIPT="$1"
        G8R_S_PATH="${G8R_HOME}/scripts/$G8R_SCRIPT"
        shift

        if [ -x "$G8R_S_PATH" ]; then
            cd "$G8R_HOME"
            G8R_TS=$(date +%Y%d%mT%H%M%S)
            G8R_ARCHIVED=logs/"${G8R_TS}-${G8R_SCRIPT}"
            G8R_DONE=logs/RAN.$(md5sum "${G8R_S_PATH}" | cut -b1-32)
            if [ -e "$G8R_DONE" ] && [ "$G8R_FORCE" = "n" ]; then
                echo "Skipped, already ran: ${G8R_SCRIPT}"
            else
                (
                    cp -va "$G8R_S_PATH" "${G8R_ARCHIVED}"
                    bash "${G8R_ARCHIVED}" "$@" && touch "${G8R_DONE}"
                ) \
                    2>&1 | tee logs/"${G8R_TS}-${G8R_SCRIPT}.log"
            fi
        else
            echo "Not found: $G8R_S_PATH" >&2
            exit 1
        fi
        ;;

    ####[ Help! ]############################################################

    help)
        NOT_FOUND=
        if [ "$COMMAND" = "help" ] && [ "${1:-}" != "" ]; then
            cat "$G8R_HOME/docs/help/$1.txt" 2>/dev/null && exit 0
            NOT_FOUND="$1"
        fi
        (
            cat <<tac
Usage: g8r <command> [...]

This is the Governator! It will curl|bash your servers into shape.

See https://github.com/pagekite/g8r for docs and details.

Commands:
tac
            [ -e "$G8R_HOME/tree/automations.json" ] && cat <<tac
    automate   Run automations defined in \$G8R_HOME/tree/automations.json
tac
            [ -e "$G8R_HOME/tools/domain-add.sh" ] && cat <<tac
    init       Peform basic setup of the Governator Server
    make       Rebuild scripts by running make in \$G8R_HOME/tree

    add-domain Add a new domain (run w/o args for help)
    add-host   Add a new host (run w/o args for help)
    etc-hosts  Update /etc/hosts on this machine using current inventory
    rm-host    Remove a host (run w/o args for help)
    hosts      Lists configured hosts: [ipv4, ipv6, fqdn, host-secret]

    deploy     Deploy a host on the VPS provider of your choice
    backups    Download the most recent backups from a host
    metrics    Fetch the metrics/monitoring data from a host
    host-cfg   Display variables configuration for a given host
    ssh        SSH (as root) into a specific host
   *push       Update a chosen script run it (over SSH) on one or more hosts
   *update     Run \`g8r run --force 900_update.sh\` on one or more hosts
   *undeploy   Undeploy a host (delete the VPS)
tac
            [ -e "$G8R_HOME/scripts/" ] && cat <<tac
    ls           List available scripts
    run X        Run script X
    healthchk X  Run only the health-check fragment of script X
    metrics      Fetch the local metrics/monitoring data
tac
            G8R=$(basename "$0")
            cat <<tac

Try \`$G8R help <command>\` (e.g. \`$G8R help add-host\`) to learn more.

[G8R_HOME=$G8R_HOME]
tac
            if [ "$NOT_FOUND" != "" ]; then
                echo "-------------------------- -- --- - - -- -- -  -"
                echo "Oops! Topic not found: $1"
            fi
        ) | $PAGER
        [ "$NOT_FOUND" != "" ] && exit 99
        ;;

    *)
        g8r help >&2
        exit 99
        ;;
esac
